---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	image: ImageMetadata;
	streamIndex: number;
	motionRange?: string;
	motionLane?: number;
}

const { title, description, image, streamIndex, motionRange, motionLane } = Astro.props;
---

<article
	class="motion-concept-card"
	role="listitem"
	style={`--stream-index: ${streamIndex}`}
	data-motion-range={motionRange}
	data-motion-lane={motionLane}
>
	<Image src={image} alt={`${title} concept illustration`} />
	<div class="card-copy">
		<h3>{title}</h3>
		<p>{description}</p>
	</div>
</article>

<style>
	.motion-concept-card {
		width: clamp(260px, 29vw, 420px);
		flex: 0 0 auto;
		box-sizing: border-box;
		overflow: hidden;
		border: 1px solid oklch(19% 0.025 205 / 22%);
		border-radius: 4px;
		background: oklch(98% 0.014 82);
		box-shadow: 0 18px 0 oklch(19% 0.025 205 / 8%);
		color: oklch(19% 0.025 205);
		transform: translateY(calc(var(--stream-index) * clamp(12px, 1.7vw, 24px)));
	}

	.motion-concept-card :global(img) {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		background: oklch(92% 0.03 82);
	}

	.card-copy {
		display: grid;
		min-height: clamp(164px, 15vw, 210px);
		align-content: start;
		padding: clamp(18px, 2.4vw, 28px);
	}

	h3 {
		margin: 0;
		font-size: clamp(1.45rem, 2.4vw, 2.25rem);
		line-height: 1;
		letter-spacing: 0;
	}

	p {
		max-width: 34ch;
		margin: clamp(12px, 1.4vw, 18px) 0 0;
		font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
		line-height: 1.5;
		color: oklch(34% 0.025 205);
	}

	@media (max-width: 640px) {
		.motion-concept-card {
			width: min(78vw, 330px);
			transform: translateY(calc(var(--stream-index) * 10px));
		}

		.card-copy {
			min-height: 156px;
		}
	}
</style>
