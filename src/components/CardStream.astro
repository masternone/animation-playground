---
import MotionConceptCard from './MotionConceptCard.astro';
import { motionConceptCards } from '../content/motionConceptCards';

interface Props {
	implementation?: 'static' | 'css' | 'gsap';
}

const { implementation = 'static' } = Astro.props;
const isCssImplementation = implementation === 'css';
const isGsapImplementation = implementation === 'gsap';
const motionRanges = ['4 36', '14 46', '24 56', '34 66', '44 76', '54 88'];
const motionLanes = [-10, -4, 2, 7, -2, 5];
const stickyReleaseProgress = 0.74;
const animatedSceneHeight = `${((stickyReleaseProgress / (1 - stickyReleaseProgress)) * 100).toFixed(3)}svh`;
---

<div
	class:list={[
		'card-stream-scene',
		isGsapImplementation && 'card-stream-scene--gsap',
		isCssImplementation && 'card-stream-scene--css',
	]}
	style={isGsapImplementation || isCssImplementation
		? `--card-stream-scene-height: ${animatedSceneHeight}`
		: undefined}
	data-gsap-card-stream-scene={isGsapImplementation ? true : undefined}
>
	{
		isCssImplementation && (
			<p class="motion-support-note">
				This Card Stream is shown without scroll-linked motion because this browser does not support
				CSS Scroll-Driven Animations.
			</p>
		)
	}
	<div
		class="card-stream-stage"
		data-gsap-card-stream-stage={isGsapImplementation ? true : undefined}
	>
		<div class="card-stream" data-card-stream role="list" aria-label="Motion concepts">
			{
				motionConceptCards.map((card, index) => (
					<MotionConceptCard
						title={card.title}
						description={card.description}
						image={card.image}
						streamIndex={index}
						motionRange={isGsapImplementation ? motionRanges[index] : undefined}
						motionLane={isGsapImplementation ? motionLanes[index] : undefined}
					/>
				))
			}
		</div>
	</div>
</div>

<script>
	import gsap from 'gsap';
	import ScrollTrigger from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const motion = gsap.matchMedia();

	motion.add('(prefers-reduced-motion: no-preference)', () => {
		const scenes = document.querySelectorAll<HTMLElement>('[data-gsap-card-stream-scene]');
		const timelines: gsap.core.Timeline[] = [];
		const pinTriggers: ScrollTrigger[] = [];

		scenes.forEach((scene) => {
			const stage = scene.querySelector<HTMLElement>('[data-gsap-card-stream-stage]');
			const cards = [...scene.querySelectorAll<HTMLElement>('.motion-concept-card')];

			if (!stage) return;

			const pinTrigger = ScrollTrigger.create({
				trigger: scene,
				start: 'top top',
				end: 'bottom bottom',
				pin: stage,
				pinSpacing: false,
				anticipatePin: 1,
				invalidateOnRefresh: true,
			});
			const playhead = { progress: 0 };
			const timeline = gsap.timeline({
				scrollTrigger: {
					trigger: scene,
					start: 'top bottom',
					end: 'bottom top',
					scrub: true,
					invalidateOnRefresh: true,
				},
			});

			timeline.to(playhead, { progress: 1, duration: 1, ease: 'none' }, 0);

			cards.forEach((card) => {
				const [rangeStart = 0, rangeEnd = 100] = (card.dataset.motionRange ?? '0 100')
					.split(' ')
					.map(Number);
				const lane = Number(card.dataset.motionLane ?? 0);
				const start = rangeStart / 100;
				const span = (rangeEnd - rangeStart) / 100;
				const position = (progress: number) => start + span * progress;

				timeline.set(
					card,
					{
						xPercent: -50,
						yPercent: -50,
						x: '70vw',
						y: `${lane + 8}svh`,
						rotation: 3,
						scale: 0.96,
						opacity: 0,
						zIndex: 0,
					},
					0,
				);
				timeline.to(
					card,
					{
						x: '32vw',
						y: `${lane + 3}svh`,
						rotation: 1,
						scale: 0.985,
						opacity: 0.72,
						zIndex: 1,
						duration: span * 0.22,
						ease: 'none',
					},
					position(0),
				);
				timeline.to(
					card,
					{
						x: '18vw',
						y: `${lane}svh`,
						rotation: 0,
						scale: 1,
						opacity: 1,
						zIndex: 3,
						duration: span * 0.16,
						ease: 'none',
					},
					position(0.22),
				);
				timeline.to(
					card,
					{
						x: '18vw',
						y: `${lane}svh`,
						opacity: 1,
						zIndex: 3,
						duration: span * 0.16,
						ease: 'none',
					},
					position(0.38),
				);
				timeline.to(
					card,
					{
						x: '-2vw',
						y: `${lane - 5}svh`,
						rotation: -1,
						scale: 0.99,
						opacity: 0.48,
						zIndex: 2,
						duration: span * 0.14,
						ease: 'none',
					},
					position(0.54),
				);
				timeline.to(
					card,
					{
						x: '-24vw',
						y: `${lane - 11}svh`,
						rotation: -2,
						scale: 0.975,
						opacity: 0.1,
						zIndex: 1,
						duration: span * 0.12,
						ease: 'none',
					},
					position(0.68),
				);
				timeline.to(
					card,
					{
						x: '-96vw',
						y: `${lane - 20}svh`,
						rotation: -3,
						scale: 0.96,
						opacity: 0,
						zIndex: 0,
						duration: span * 0.2,
						ease: 'none',
					},
					position(0.8),
				);
			});

			timelines.push(timeline);
			pinTriggers.push(pinTrigger);
		});

		return () => {
			timelines.forEach((timeline) => {
				timeline.scrollTrigger?.kill();
				timeline.kill();
			});
			pinTriggers.forEach((trigger) => trigger.kill());
		};
	});
</script>

<style>
	.card-stream-scene {
		position: relative;
	}

	.card-stream-stage {
		position: relative;
	}

	.motion-support-note {
		display: block;
		max-width: 48ch;
		margin: 0 0 32px;
		padding: 16px 18px;
		border: 1px solid oklch(92% 0.025 82 / 32%);
		background: oklch(19% 0.025 205 / 32%);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.card-stream {
		display: flex;
		width: max-content;
		max-width: none;
		align-items: flex-start;
		gap: clamp(16px, 2.4vw, 36px);
		margin-inline: calc(var(--page-gutter) * -1);
		padding: 0 var(--page-gutter) clamp(96px, 12vw, 176px);
	}

	.card-stream-scene--css .card-stream {
		display: grid;
		width: 100%;
		grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
		margin-inline: 0;
		padding-inline: 0;
	}

	.card-stream-scene--css .card-stream :global(.motion-concept-card) {
		width: 100%;
		transform: none;
	}

	.card-stream-scene--gsap {
		min-height: var(--card-stream-scene-height);
	}

	.card-stream-scene--gsap .card-stream-stage {
		position: relative;
		display: grid;
		min-height: 100svh;
		align-items: center;
		overflow: clip;
	}

	.card-stream-scene--gsap .card-stream {
		position: relative;
		display: block;
		width: 100%;
		height: min(72svh, 720px);
		margin-inline: 0;
		padding: 0;
	}

	.card-stream-scene--gsap .card-stream :global(.motion-concept-card) {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		will-change: transform, opacity;
	}

	@media (prefers-reduced-motion: no-preference) {
		.card-stream-scene--gsap .card-stream :global(.motion-concept-card) {
			opacity: 0;
		}
	}

	@supports (animation-timeline: view()) {
		.card-stream-scene--css {
			min-height: var(--card-stream-scene-height);
			view-timeline-name: --css-card-stream;
			view-timeline-axis: block;
		}

		.card-stream-scene--css .motion-support-note {
			display: none;
		}

		.card-stream-scene--css .card-stream-stage {
			position: sticky;
			top: 0;
			display: grid;
			min-height: 100svh;
			align-items: center;
			overflow: clip;
		}

		.card-stream-scene--css .card-stream {
			position: relative;
			display: block;
			width: 100%;
			height: min(72svh, 720px);
			margin-inline: 0;
			padding: 0;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card) {
			--stream-lane: 0svh;

			position: absolute;
			top: 50%;
			left: 50%;
			width: clamp(260px, 29vw, 420px);
			opacity: 0;
			transform: translate3d(calc(-50% + 70vw), calc(-50% + var(--stream-lane) + 8svh), 0)
				rotate(3deg) scale(0.96);
			will-change: transform, opacity;
			animation-name: css-card-flow;
			animation-duration: 1ms;
			animation-timing-function: linear;
			animation-fill-mode: both;
			animation-timeline: --css-card-stream;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(1)) {
			--stream-lane: -10svh;
			animation-range: 4% 36%;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(2)) {
			--stream-lane: -4svh;
			animation-range: 14% 46%;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(3)) {
			--stream-lane: 2svh;
			animation-range: 24% 56%;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(4)) {
			--stream-lane: 7svh;
			animation-range: 34% 66%;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(5)) {
			--stream-lane: -2svh;
			animation-range: 44% 76%;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card:nth-child(6)) {
			--stream-lane: 5svh;
			animation-range: 54% 88%;
		}
	}

	@keyframes css-card-flow {
		0% {
			z-index: 0;
			opacity: 0;
			transform: translate3d(calc(-50% + 70vw), calc(-50% + var(--stream-lane) + 8svh), 0)
				rotate(3deg) scale(0.96);
		}

		22% {
			z-index: 1;
			opacity: 0.72;
			transform: translate3d(calc(-50% + 32vw), calc(-50% + var(--stream-lane) + 3svh), 0)
				rotate(1deg) scale(0.985);
		}

		38%,
		54% {
			z-index: 3;
			opacity: 1;
			transform: translate3d(calc(-50% + 18vw), calc(-50% + var(--stream-lane)), 0)
				rotate(0deg) scale(1);
		}

		68% {
			z-index: 2;
			opacity: 0.48;
			transform: translate3d(calc(-50% - 2vw), calc(-50% + var(--stream-lane) - 5svh), 0)
				rotate(-1deg) scale(0.99);
		}

		80% {
			z-index: 1;
			opacity: 0.1;
			transform: translate3d(calc(-50% - 24vw), calc(-50% + var(--stream-lane) - 11svh), 0)
				rotate(-2deg) scale(0.975);
		}

		100% {
			z-index: 0;
			opacity: 0;
			transform: translate3d(calc(-50% - 96vw), calc(-50% + var(--stream-lane) - 20svh), 0)
				rotate(-3deg) scale(0.96);
		}
	}

	@media (max-width: 640px) {
		.card-stream {
			gap: 14px;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card) {
			width: min(76vw, 320px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.card-stream-scene--gsap {
			min-height: auto;
		}

		.card-stream-scene--gsap .card-stream-stage {
			position: relative;
			top: auto;
			display: block;
			min-height: auto;
			overflow: visible;
		}

		.card-stream-scene--gsap .card-stream {
			display: grid;
			width: 100%;
			height: auto;
			grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
			margin-inline: 0;
			padding: 0;
		}

		.card-stream-scene--gsap .card-stream :global(.motion-concept-card) {
			position: relative;
			inset: auto;
			width: 100%;
			opacity: 1;
			transform: none;
			will-change: auto;
		}

		.card-stream-scene--css {
			min-height: auto;
			view-timeline-name: none;
		}

		.card-stream-scene--css .card-stream-stage {
			position: relative;
			top: auto;
			display: block;
			min-height: auto;
			overflow: visible;
		}

		.card-stream-scene--css .card-stream {
			display: grid;
			width: 100%;
			height: auto;
			grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
			margin-inline: 0;
			padding: 0;
		}

		.card-stream-scene--css .card-stream :global(.motion-concept-card) {
			position: relative;
			inset: auto;
			width: 100%;
			opacity: 1;
			transform: none;
			animation: none;
			will-change: auto;
		}
	}
</style>
