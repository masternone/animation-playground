	.c5 { --burst-x: 48px; --burst-y: -268px; --fall-x: -58px; --spin: 46deg; --delay: 210ms; }
	.c6 { --burst-x: 104px; --burst-y: -330px; --fall-x: 84px; --spin: -72deg; --delay: 135ms; }
	.c7 { --burst-x: 146px; --burst-y: -226px; --fall-x: -34px; --spin: 28deg; --delay: 75ms; }
	.c8 { --burst-x: 166px; --burst-y: -162px; --fall-x: 60px; --spin: 92deg; --delay: 185ms; }
	.c9 { --burst-x: -174px; --burst-y: -138px; --fall-x: -56px; --spin: 22deg; --delay: 245ms; }
	.c10 { --burst-x: -102px; --burst-y: -126px; --fall-x: 38px; --spin: -120deg; --delay: 280ms; }
	.c11 { --burst-x: 98px; --burst-y: -122px; --fall-x: -70px; --spin: 140deg; --delay: 260ms; }
	.c12 { --burst-x: 174px; --burst-y: -92px; --fall-x: 50px; --spin: -28deg; --delay: 300ms; }

	@keyframes hover-drift {
		from {
			margin-top: -5px;
		}

		to {
			margin-top: 9px;
		}
	}

	@media (min-width: 681px) {
		.gift-stage {
			width: min(88vw, 860px);
			aspect-ratio: 1.5;
		}

		.gift-box {
			width: min(70vw, 520px);
		}

		.confetti {
			top: 62%;
		}

		.c1 { --burst-x: -390px; --burst-y: -292px; }
		.c2 { --burst-x: -286px; --burst-y: -382px; }
		.c3 { --burst-x: -164px; --burst-y: -280px; }
		.c4 { --burst-x: -56px; --burst-y: -412px; }
		.c5 { --burst-x: 82px; --burst-y: -326px; }
