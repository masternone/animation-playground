		.c11 { --burst-x: 240px; --burst-y: -162px; }
		.c12 { --burst-x: 426px; --burst-y: -112px; }
	}

	@media (prefers-reduced-motion: reduce) {
		.box-lid,
		.confetti {
			transition-duration: 1ms;
			animation: none;
		}
	}
</style>
