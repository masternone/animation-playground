---
import Layout from '../layouts/Layout.astro';
import GiftBoxHero from '../components/GiftBoxHero.astro';
---

<Layout title="Gift Box Hero">
	<main>
		<GiftBoxHero />
		<section class="scroll-panel" aria-label="Follow-up content">
			<h1>Animation Playground</h1>
			<p>Scroll back to reset the suspended celebration, then drift down again to let it fall away.</p>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: #172126;
		background: #fffaf2;
	}

	main {
		min-height: 180svh;
	}

	.scroll-panel {
		display: grid;
		min-height: 80svh;
		place-content: center;
		padding: 64px 24px;
		text-align: center;
		background: #172126;
		color: #fffaf2;
	}

	.scroll-panel h1 {
		margin: 0;
		font-size: clamp(2.5rem, 8vw, 7rem);
		font-weight: 800;
		letter-spacing: 0;
	}

	.scroll-panel p {
		max-width: 40rem;
		margin: 20px auto 0;
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.6;
		color: rgb(255 250 242 / 78%);
	}
</style>
