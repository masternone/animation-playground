---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scroll Card Gallery">
	<main>
		<section class="hero" aria-labelledby="page-title">
			<div class="hero-content">
				<p class="eyebrow">Browser motion study</p>
				<h1 id="page-title">Scroll Card Gallery</h1>
				<p class="lede">
					One motion contract, explored through GSAP ScrollTrigger and native CSS scroll-driven
					animations.
				</p>
			</div>
		</section>

		<section class="comparison-stage comparison-stage--gsap" data-gsap-stage aria-labelledby="gsap-title">
			<div class="stage-heading">
				<p class="stage-number">01</p>
				<h2 id="gsap-title">GSAP ScrollTrigger</h2>
				<p>Scripted timelines with pinning, scrubbing, and precise choreography.</p>
			</div>
			<div class="stage-slot" data-card-stream-slot aria-hidden="true"></div>
		</section>

		<section class="comparison-stage comparison-stage--css" data-css-stage aria-labelledby="css-title">
			<div class="stage-heading">
				<p class="stage-number">02</p>
				<h2 id="css-title">CSS Scroll-Driven Animations</h2>
				<p>Native browser timelines tied directly to scroll and view progress.</p>
			</div>
			<div class="stage-slot" data-card-stream-slot aria-hidden="true"></div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: #f6f1e7;
		background: #121617;
	}

	main {
		min-height: 100svh;
	}

	.hero {
		display: grid;
		min-height: 100svh;
		place-items: end start;
		padding: clamp(96px, 14vw, 180px) var(--page-gutter);
		box-sizing: border-box;
		background:
			linear-gradient(180deg, rgb(18 22 23 / 6%) 30%, rgb(18 22 23 / 92%) 100%),
			linear-gradient(135deg, #315e68 0%, #987245 48%, #913f4e 100%);
	}

	.hero-content {
		max-width: 74rem;
	}

	.eyebrow {
		margin: 0 0 16px;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 11ch;
		margin: 0;
		font-size: clamp(3.5rem, 10vw, 8.5rem);
		line-height: 0.92;
		letter-spacing: 0;
	}

	.lede {
		max-width: 42rem;
		margin: 28px 0 0;
		font-size: clamp(1rem, 2vw, 1.3rem);
		line-height: 1.55;
		color: rgb(246 241 231 / 82%);
	}

	.comparison-stage {
		position: relative;
		display: grid;
		min-height: 100svh;
		align-content: start;
		overflow: hidden;
		padding: clamp(72px, 9vw, 128px) var(--page-gutter);
		box-sizing: border-box;
	}

	.comparison-stage--gsap {
		color: #17191a;
		background: #f1ede3;
	}

	.comparison-stage--css {
		color: #f5f0e6;
		background: #243c3f;
	}

	.stage-heading {
		position: relative;
		z-index: 1;
		max-width: 48rem;
	}

	.stage-number {
		margin: 0 0 20px;
		font-size: 0.75rem;
		font-weight: 800;
	}

	h2 {
		margin: 0;
		font-size: clamp(2.5rem, 7vw, 6.5rem);
		line-height: 0.98;
		letter-spacing: 0;
	}

	.stage-heading > :last-child {
		max-width: 36rem;
		margin: 24px 0 0;
		font-size: clamp(1rem, 1.8vw, 1.2rem);
		line-height: 1.55;
		opacity: 0.72;
	}

	.stage-slot {
		min-height: 42svh;
		margin-top: clamp(48px, 8vw, 112px);
		border-block: 1px solid currentColor;
		opacity: 0.18;
	}
</style>
