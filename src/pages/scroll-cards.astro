---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CardStream from '../components/CardStream.astro';
import scrollCardsHeroImage from '../images/scroll-cards-hero.webp';
---

<Layout title="Scroll Card Gallery">
	<main>
		<section class="hero" aria-labelledby="page-title">
			<Image
				class="hero-image"
				src={scrollCardsHeroImage}
				alt="Layered motion cards sweeping across a colorful browser animation stage"
				loading="eager"
			/>
			<div class="hero-content">
				<p class="eyebrow">Browser motion study</p>
				<h1 id="page-title">Scroll Card Gallery</h1>
				<p class="lede">
					One motion contract, explored through GSAP ScrollTrigger and native CSS scroll-driven
					animations.
				</p>
			</div>
		</section>

		<section class="comparison-stage comparison-stage--gsap" data-gsap-stage aria-labelledby="gsap-title">
			<div class="stage-heading">
				<p class="stage-number">01</p>
				<h2 id="gsap-title">GSAP ScrollTrigger</h2>
				<p>Scripted timelines with pinning, scrubbing, and precise choreography.</p>
			</div>
			<div class="stage-slot">
				<CardStream implementation="gsap" />
			</div>
		</section>

		<section class="comparison-stage comparison-stage--css" data-css-stage aria-labelledby="css-title">
			<div class="stage-heading">
				<p class="stage-number">02</p>
				<h2 id="css-title">CSS Scroll-Driven Animations</h2>
				<p>Native browser timelines tied directly to scroll and view progress.</p>
			</div>
			<div class="stage-slot">
				<CardStream implementation="css" />
			</div>
		</section>

		<section class="scroll-panel" aria-label="Follow-up content">
			<h2>Animation Playground</h2>
			<p>Scroll back to compare the motion contract again, then drift down to leave the Card Stream behind.</p>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: oklch(96% 0.018 82);
		background: oklch(19% 0.025 205);
	}

	main {
		min-height: 100svh;
	}

	.hero {
		position: relative;
		display: grid;
		min-height: 100svh;
		place-items: end start;
		padding: clamp(96px, 14vw, 180px) var(--page-gutter);
		box-sizing: border-box;
		background:
			linear-gradient(180deg, oklch(19% 0.025 205 / 6%) 30%, oklch(19% 0.025 205 / 92%) 100%),
			linear-gradient(135deg, oklch(43% 0.065 205) 0%, oklch(59% 0.09 68) 48%, oklch(44% 0.13 8) 100%);
		overflow: hidden;
	}

	.hero::after {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, oklch(19% 0.025 205 / 8%) 0%, oklch(19% 0.025 205 / 78%) 72%, oklch(19% 0.025 205) 100%),
			linear-gradient(90deg, oklch(19% 0.025 205 / 78%) 0%, oklch(19% 0.025 205 / 26%) 54%, oklch(19% 0.025 205 / 62%) 100%);
		content: '';
	}

	.hero-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 74rem;
	}

	.eyebrow {
		margin: 0 0 16px;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 11ch;
		margin: 0;
		font-size: clamp(3.5rem, 10vw, 8.5rem);
		line-height: 0.92;
		letter-spacing: 0;
	}

	.lede {
		max-width: 42rem;
		margin: 28px 0 0;
		font-size: clamp(1rem, 2vw, 1.3rem);
		line-height: 1.55;
		color: rgb(246 241 231 / 82%);
	}

	.comparison-stage {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		min-height: 100svh;
		align-content: start;
		overflow: hidden;
		padding: clamp(72px, 9vw, 128px) var(--page-gutter);
		box-sizing: border-box;
	}

	.comparison-stage--gsap {
		overflow: clip;
		color: oklch(19% 0.025 205);
		background: oklch(94% 0.018 82);
	}

	.comparison-stage--css {
		overflow: clip;
		color: oklch(96% 0.018 82);
		background: oklch(30% 0.045 195);
	}

	.comparison-stage--gsap .stage-heading,
	.comparison-stage--css .stage-heading {
		position: sticky;
		top: clamp(24px, 5svh, 52px);
		z-index: 5;
		max-width: min(46rem, 58vw);
	}

	.stage-heading {
		position: relative;
		z-index: 1;
		max-width: 48rem;
	}

	.stage-number {
		display: inline-grid;
		width: 44px;
		height: 44px;
		margin: 0 0 20px;
		place-items: center;
		border: 1px solid currentColor;
		border-radius: 50%;
		font-size: 0.75rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
		opacity: 0.76;
	}

	.stage-heading h2 {
		margin: 0;
		font-size: clamp(2.5rem, 7vw, 6.5rem);
		line-height: 0.98;
		letter-spacing: 0;
	}

	.stage-heading > :last-child {
		max-width: 36rem;
		margin: 24px 0 0;
		font-size: clamp(1rem, 1.8vw, 1.2rem);
		line-height: 1.55;
		opacity: 0.72;
	}

	.stage-slot {
		position: relative;
		z-index: 1;
		margin-top: clamp(48px, 8vw, 112px);
	}

	.scroll-panel {
		display: grid;
		min-height: 100svh;
		align-content: center;
		justify-content: start;
		justify-items: start;
		padding: 64px var(--page-gutter);
		text-align: left;
		background: oklch(19% 0.025 205);
		color: oklch(98% 0.014 82);
	}

	.scroll-panel h2 {
		margin: 0;
		font-size: clamp(2.5rem, 8vw, 7rem);
		font-weight: 800;
		line-height: normal;
		letter-spacing: 0;
	}

	.scroll-panel p {
		max-width: 40rem;
		margin: 20px 0 0;
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.6;
		color: oklch(98% 0.014 82 / 78%);
	}

	@media (max-width: 640px) {
		.comparison-stage--gsap .stage-heading,
		.comparison-stage--css .stage-heading {
			top: 20px;
			max-width: 100%;
		}
	}
</style>
